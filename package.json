{
  "name": "@dowonk-7949/llm-wiki-standard",
  "version": "1.6.0",
  "private": false,
  "type": "module",
  "description": "Stable CLI for the cross-platform LLM-WIKI common standard.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dowon-Kim7949/llm-wiki-standard.git"
  },
  "files": [
    "bin",
    "src",
    "templates",
    "rules",
    "adapters",
    "profiles",
    "README.md",
    "README.ko.md",
    "CHANGELOG.md",
    "CHANGELOG.ko.md",
    "ROADMAP.md",
    "ROADMAP.ko.md",
    "GATE_REVIEW.md",
    "VERIFICATION.md",
    "RELEASE_CHECKLIST.md",
    "CODE_OF_CONDUCT.md",
    "CODE_OF_CONDUCT.ko.md",
    "CONTRIBUTING.md",
    "CONTRIBUTING.ko.md",
    "SECURITY.md",
    "SECURITY.ko.md",
    "LICENSE"
  ],
  "bin": {
    "llm-wiki": "bin/llm-wiki.js"
  },
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "verify": "node --test tests/*.test.js && node bin/llm-wiki.js validate-frontmatter",
    "doctor": "node bin/llm-wiki.js doctor",
    "audit": "node bin/llm-wiki.js audit",
    "validate": "node bin/llm-wiki.js validate",
    "validate-frontmatter": "node bin/llm-wiki.js validate-frontmatter"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "license": "MIT"
}

